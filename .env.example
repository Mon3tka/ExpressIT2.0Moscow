# Upstash Redis (обязательно для Vercel)
# Создайте базу на https://console.upstash.com/ и добавьте в Vercel → Settings → Environment Variables
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# Пароль админа (по умолчанию admin123)
ADMIN_PASSWORD=admin123

# Секрет для JWT (смените в продакшене)
JWT_SECRET=expressit-jwt-secret-change-in-production
